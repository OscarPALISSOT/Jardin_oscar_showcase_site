FROM node:latest

WORKDIR /app

ARG NEXT_DIRECTUS_INTERNAL_URL
ARG NEXT_PUBLIC_ASSETS_URL
ARG NEXT_PUBLIC_RECAPTCHA_CLIENT_KEY
ARG RECAPTCHA_SECRET_KEY

ENV NEXT_DIRECTUS_INTERNAL_URL=$NEXT_DIRECTUS_INTERNAL_URL
ENV NEXT_PUBLIC_ASSETS_URL=$NEXT_PUBLIC_ASSETS_URL
ENV NEXT_PUBLIC_RECAPTCHA_CLIENT_KEY=$NEXT_PUBLIC_RECAPTCHA_CLIENT_KEY
ENV RECAPTCHA_SECRET_KEY=$RECAPTCHA_SECRET_KEY

COPY . .

RUN npm install

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
